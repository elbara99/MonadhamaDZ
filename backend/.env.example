# MonadhamaDZ Backend — Environment Variables
# Copy this file to .env and fill in your values.

APP_NAME=MonadhamaDZ API
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# Security
SECRET_KEY=change-me-to-a-long-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL
POSTGRES_USER=monadhama
POSTGRES_PASSWORD=monadhama
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=monadhama

# Redis (optional — prepared for future use)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
